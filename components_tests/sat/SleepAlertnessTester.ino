// ═══════════════════════════════════════════════════════════
//  QUESTION BANK
//  3 pools: Easy / Medium / Hard  — 3 questions drawn per round
// ═══════════════════════════════════════════════════════════
struct Q { const char* text; const char* answer; uint16_t budget; };

const Q EASY[] = {
