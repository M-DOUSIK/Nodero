<script>
const DC=['d0','d1','d2'],DL=['EASY','MEDIUM','HARD'];
let R=0,Q=0,lim=0,t0=0,tmr=null,results=[[],[],[]],roundCorr=[];
const $=id=>document.getElementById(id);
const show=id=>{document.querySelectorAll('.screen').forEach(s=>s.classList.remove('on'));$(id).classList.add('on');}
const prog=p=>$('prog').style.width=p+'%';
const clr=()=>{clearInterval(tmr);tmr=null;}
const wait=ms=>new Promise(r=>setTimeout(r,ms));
const sc=s=>s>=68?'var(--grn)':s>=40?'var(--amb)':'var(--red)';
const tr=(s,n)=>s.length>n?s.slice(0,n)+'…':s;

async function start(){
  R=0;Q=0;results=[[],[],[]];roundCorr=[];
  prog(0);
  await fetch('/api/start',{method:'POST'});
  await loadQ();show('s1');
}

async function loadQ(){
  clr();
  $('ans').value='';$('ans').className='';$('fb').style.display='none';
  $('sbtn').disabled=false;
  prog(((R*3+Q)/9)*100);
  const d=await fetch('/api/q').then(r=>r.json());
  $('rtag').innerHTML=`ROUND ${R+1} OF 3 <span class="diff ${DC[R]}">${DL[R]}</span> &nbsp;Q${Q+1}/3`;
  $('qtext').textContent=d.q;
  lim=d.ms;
  tick();
  setTimeout(()=>$('ans').focus(),60);
}

function tick(){
  clr();t0=Date.now();
  const fill=$('tfill'),val=$('tval');
  tmr=setInterval(()=>{
    const rem=Math.max(0,lim-(Date.now()-t0)),p=rem/lim*100;
    fill.style.width=p+'%';
    const c=p>50?'var(--grn)':p>22?'var(--amb)':'var(--red)';
    fill.style.background=c;val.style.color=c;
    val.textContent=(rem/1000).toFixed(1)+'s';
    if(!rem){clr();submit(true);}
  },80);
}

async function submit(tout=false){
  clr();
  const elapsed=Date.now()-t0;
  const a=tout?'':$('ans').value.trim();
  $('sbtn').disabled=true;
  const d=await fetch('/api/ans',{
    method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({a,ms:elapsed})
  }).then(r=>r.json());
  const fb=$('fb');fb.style.display='block';
  if(d.ok){
    fb.className='feedback f-ok';fb.textContent='✓ CORRECT — '+d.ms+'ms';
    $('ans').classList.add('ok');
  } else {
    fb.className='feedback f-bad';
    fb.textContent=(tout?'✗ TIMED OUT':'✗ WRONG')+' — answer: '+d.ans;
    $('ans').classList.add('bad');
  }
  results[R].push({ok:d.ok,ms:d.ms,q:d.q});
  await wait(1350);
  Q++;
  if(Q>=3){
    roundCorr.push(results[R].filter(x=>x.ok).length);
    showRS();
  } else {
    await loadQ();
  }
}

function showRS(){
  show('s2');
  const corr=roundCorr[R];
  $('rslabel').textContent=`ROUND ${R+1} COMPLETE`;
  const el=$('rsscore');
  el.textContent=corr+'/3';
  el.style.color=corr>=2?'var(--grn)':corr>=1?'var(--amb)':'var(--red)';
  const ul=$('rslist');ul.innerHTML='';
  results[R].forEach(x=>{
    const li=document.createElement('li');
    li.innerHTML=`<span class="q-txt">${tr(x.q,38)}</span><span class="badge ${x.ok?'b-ok':'b-bad'}">${x.ok?'OK':'FAIL'}</span><span class="q-ms">${(x.ms/1000).toFixed(1)}s</span>`;
    ul.appendChild(li);
  });
  prog((R+1)/3*100);
  const nb=$('rsnext');
  if(R+1>=3){nb.textContent='VIEW RESULTS →';nb.onclick=showFinal;}
  else{nb.textContent=`START ROUND ${R+2} →`;nb.onclick=()=>{R++;Q=0;show('s1');loadQ();};}
}

async function showFinal(){
  show('s3');prog(100);
  const d=await fetch('/api/result').then(r=>r.json());
  const s=Math.round(d.score);
  $('fscore').textContent=s;$('fscore').style.color=sc(d.score);
  $('fverdict').textContent=d.verdict;$('fverdict').style.color=sc(d.score);
  $('fbreakdown').innerHTML=`
    <div class="row"><span class="row-label">ROUND 1 (EASY)</span><span class="row-val">${d.acc[0]}/3 correct</span></div>
    <div class="row"><span class="row-label">ROUND 2 (MEDIUM)</span><span class="row-val">${d.acc[1]}/3 correct</span></div>
    <div class="row"><span class="row-label">ROUND 3 (HARD)</span><span class="row-val">${d.acc[2]}/3 correct</span></div>
    <div class="row"><span class="row-label">AVG RESPONSE TIME</span><span class="row-val">${d.avgMs}ms</span></div>
    <div class="row"><span class="row-label">RESPONSE VARIANCE (σ)</span><span class="row-val">${d.variance}ms</span></div>
    <div class="row total"><span class="row-label" style="color:var(--txt)">ML SLEEP SCORE</span>
      <span class="row-val" style="font-size:15px;color:${sc(d.score)}">${d.score.toFixed(1)}</span></div>`;
}
</script>
