// ═══════════════════════════════════════════════════════════
//  SESSION LOGIC
// ═══════════════════════════════════════════════════════════
void sesStart() {
  memset(&ses, 0, sizeof(ses));
  ses.active = true;
  for (uint8_t r=0;r<ROUNDS;r++) pickRound(r);
  ses.qStart = millis();
}

void sesAnswer(const String& input) {
  uint32_t ms = millis() - ses.qStart;
  ses.ans[ses.round][ses.qi] = { checkAns(input), ms };
  ses.qi++;
  if (ses.qi >= QS_PER) { ses.round++; ses.qi = 0; }
  if (ses.round >= ROUNDS) { ses.score = runScorer(); ses.done = true; ses.active = false; }
  ses.qStart = millis();
}

// ═══════════════════════════════════════════════════════════
//  API
// ═══════════════════════════════════════════════════════════
void apiStart(AsyncWebServerRequest* req) {
  sesStart();
  req->send(200, "application/json", "{\"ok\":true}");
}

void apiQ(AsyncWebServerRequest* req) {
  const Q& q = curQ();
  String j = "{\"q\":\"" + String(q.text) + "\",\"ms\":" + String(q.budget) + "}";
  req->send(200, "application/json", j);
}

void apiAns(AsyncWebServerRequest* req, uint8_t* data, size_t len, size_t, size_t) {
  String body((char*)data, len);

  // Parse "a" field
  String input = "";
  int ai = body.indexOf("\"a\":\"");
  if (ai >= 0) { int s=ai+5, e=body.indexOf("\"",s); if(e>s) input=body.substring(s,e); }

  bool wasOk   = checkAns(input);
  String qText = String(curQ().text);
  String qAns  = String(curQ().answer);
  uint32_t ms  = millis() - ses.qStart;

  sesAnswer(input);

  String j = "{\"ok\":"  + String(wasOk?"true":"false") +
             ",\"ms\":"  + String(ms) +
             ",\"ans\":\"" + qAns  + "\"" +
             ",\"q\":\""   + qText + "\"}";
  req->send(200, "application/json", j);
}

void apiResult(AsyncWebServerRequest* req) {
  uint8_t acc[3]={};
  double allMs[9]; uint8_t ti=0; double sumMs=0;
  for (uint8_t r=0;r<ROUNDS;r++)
    for (uint8_t q=0;q<QS_PER;q++) {
      if (ses.ans[r][q].ok) acc[r]++;
      allMs[ti]=ses.ans[r][q].ms; sumMs+=allMs[ti++];
    }
  double mean=sumMs/9, var=0;
  for(uint8_t i=0;i<9;i++) var+=(allMs[i]-mean)*(allMs[i]-mean);

  String j = "{\"score\":"   + String(ses.score,1) +
             ",\"verdict\":\"" + String(verdict(ses.score)) + "\"" +
             ",\"acc\":["    + acc[0] + "," + acc[1] + "," + acc[2] + "]" +
             ",\"avgMs\":"   + String((uint32_t)(sumMs/9)) +
             ",\"variance\":" + String((uint32_t)sqrt(var/9.0)) + "}";
  req->send(200, "application/json", j);
}

// ═══════════════════════════════════════════════════════════
//  SETUP / LOOP
// ═══════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  randomSeed(esp_random());

  // Pure Access Point mode — ESP32-S3 IS the WiFi hotspot
  WiFi.mode(WIFI_AP);
  WiFi.softAP(AP_SSID, AP_PASS);
  delay(500);  // let AP stabilise before anything else

  IPAddress ip = WiFi.softAPIP();
  Serial.println("\n[AP] SSID    : " + String(AP_SSID));
  Serial.println("[AP] Password: " + String(AP_PASS));
  Serial.println("[AP] Open    : http://" + ip.toString());

  server.on("/",          HTTP_GET,  [](AsyncWebServerRequest* r){ r->send_P(200,"text/html",PAGE); });
  server.on("/api/start", HTTP_POST, apiStart);
  server.on("/api/q",     HTTP_GET,  apiQ);
  server.on("/api/ans",   HTTP_POST, [](AsyncWebServerRequest*){}, NULL, apiAns);
  server.on("/api/result",HTTP_GET,  apiResult);
  DefaultHeaders::Instance().addHeader("Access-Control-Allow-Origin","*");
  server.begin();
  Serial.println("[HTTP] ready");
}
void loop(){ delay(10); }
