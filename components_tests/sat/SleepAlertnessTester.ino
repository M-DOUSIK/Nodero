  {"What is 20 / 4?",                             "5",       8000},
};
const Q MEDIUM[] = {
  {"What is 13 x 7?",                             "91",      11000},
  {"Spell backwards: CAT",                        "tac",     9000},
  {"Next: 2, 4, 8, 16, ___",                      "32",      11000},
  {"Opposite of ANCIENT?",                        "modern",  9000},
  {"Repeat this: 7 3 9",                          "7 3 9",   10000},
  {"Odd one out: Tennis, Football, Bat, Cricket?","bat",     11000},
  {"What is 8 squared?",                          "64",      11000},
  {"Spell backwards: DOG",                        "god",     9000},
  {"What is 144 / 12?",                           "12",      11000},
  {"Opposite of SHALLOW?",                        "deep",    9000},
};
const Q HARD[] = {
  {"What is 17 x 13?",                                "221",       14000},
  {"Spell backwards: SLEEP",                          "peels",     12000},
  {"Next: 1, 1, 2, 3, 5, 8, ___",                    "13",        12000},
  {"Odd one out: Oxygen, Nitrogen, Iron, Helium?",    "iron",      13000},
  {"Repeat this: 4 7 2 9 1",                          "4 7 2 9 1", 13000},
  {"Next: 3, 9, 27, 81, ___",                         "243",       13000},
  {"What is 256 / 16?",                               "16",        14000},
  {"Odd one out: Jupiter, Mars, Moon, Saturn?",       "moon",      13000},
  {"Synonym of FATIGUED?",                            "tired",     12000},
  {"What is 12 squared minus 44?",                    "100",       14000},
};
#define POOL_SZ 10
#define ROUNDS   3
#define QS_PER   3

// ═══════════════════════════════════════════════════════════
//  SESSION
// ═══════════════════════════════════════════════════════════
struct Ans { bool ok; uint32_t ms; };

struct Session {
  bool    active, done;
  uint8_t round, qi;
  uint8_t idx[ROUNDS][QS_PER];
  Ans     ans[ROUNDS][QS_PER];
  uint32_t qStart;
  float   score;
};
Session ses;

void shuffle(uint8_t* a, uint8_t n) {
  for (int i = n-1; i > 0; i--) { uint8_t j=random(i+1), t=a[i]; a[i]=a[j]; a[j]=t; }
}
void pickRound(uint8_t r) {
  uint8_t pool[POOL_SZ]; for (uint8_t i=0;i<POOL_SZ;i++) pool[i]=i;
  shuffle(pool, POOL_SZ);
  for (uint8_t i=0;i<QS_PER;i++) ses.idx[r][i]=pool[i];
}
const Q& curQ() {
  uint8_t i = ses.idx[ses.round][ses.qi];
  return ses.round==0 ? EASY[i] : ses.round==1 ? MEDIUM[i] : HARD[i];
}
bool checkAns(const String& raw) {
  String u=raw; u.trim(); u.toLowerCase();
  String e=String(curQ().answer); e.toLowerCase();
  return u==e;
}

// ═══════════════════════════════════════════════════════════
//  FEATURE EXTRACTION + ML SCORING
// ═══════════════════════════════════════════════════════════
const char* verdict(float s) {
  if (s >= 85) return "FULLY ALERT";
  if (s >= 68) return "MILDLY DROWSY";
  if (s >= 50) return "MODERATELY SLEEPY";
  if (s >= 30) return "SEVERELY IMPAIRED";
  return "CRITICALLY SLEEP-DEPRIVED";
}

float runScorer() {
  double r_acc[3]={}, r_spd[3]={};
  double all_times[9]; uint8_t ti=0;

  for (uint8_t r=0;r<ROUNDS;r++) {
    uint8_t ok=0; double spd_sum=0;
    for (uint8_t q=0;q<QS_PER;q++) {
      if (ses.ans[r][q].ok) ok++;
      spd_sum    += ses.ans[r][q].ms;
      all_times[ti++] = ses.ans[r][q].ms;
    }
    r_acc[r] = ok / (double)QS_PER;
    r_spd[r] = spd_sum / QS_PER;
  }

  // Response variance — std dev of all 9 response times
  double mean=0;
  for (uint8_t i=0;i<9;i++) mean+=all_times[i];
  mean/=9;
  double var=0;
  for (uint8_t i=0;i<9;i++) var+=(all_times[i]-mean)*(all_times[i]-mean);
  double stddev = sqrt(var/9.0);

  // Feature vector — must match training order in Colab notebook
  double feats[9] = {
    r_acc[0], r_acc[1], r_acc[2],        // accuracy per round
    r_spd[0], r_spd[1], r_spd[2],        // avg response time per round (ms)
    r_spd[2] - r_spd[0],                 // speed_trend  (+ = slowing = bad)
    r_acc[2] - r_acc[0],                 // acc_trend    (- = dropping = bad)
    stddev                                // response_variance (ms)
  };

  Serial.printf("[ML] acc=[%.2f %.2f %.2f] spd=[%.0f %.0f %.0f] "
                "spd_trend=%.0f acc_trend=%.2f var=%.0f\n",
    feats[0],feats[1],feats[2],feats[3],feats[4],
    feats[5],feats[6],feats[7],feats[8]);

  float s = score_session(feats);   // ← m2cgen generated function
  Serial.printf("[ML] Score: %.1f — %s\n", s, verdict(s));
  return s;
}

